# vsftpd config — secure FTP (chroot) mode
# Managed by Ansible — do not edit manually

anonymous_enable=NO
local_enable=YES
write_enable=YES
local_umask=022
dirmessage_enable=YES
xferlog_enable=YES
xferlog_std_format=YES
xferlog_file=/var/log/vsftpd_sftp.log

connect_from_port_20=YES
listen=YES
listen_ipv6=NO
listen_port={{ vsftpd_sftp_port }}

pam_service_name=vsftpd
userlist_enable=YES

# Chroot each local user to their home
chroot_local_user=YES
user_sub_token=$USER
local_root={{ sftp_root }}/$USER

# PASV range
pasv_enable=YES
pasv_min_port={{ vsftpd_sftp_pasv_min_port }}
pasv_max_port={{ vsftpd_sftp_pasv_max_port }}
